# =============================================================================
# Internal Monitoring System - Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# -- Database --
POSTGRES_USER=monitor
POSTGRES_PASSWORD=monitor_secret_change_me
POSTGRES_DB=monitor_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://monitor:monitor_secret_change_me@postgres:5432/monitor_db

# -- Redis --
REDIS_URL=redis://redis:6379/0

# -- Backend --
SECRET_KEY=change-me-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_CORS_ORIGINS=["http://localhost:3040","https://monitoring-system.ccrolabs.com"]
LOG_LEVEL=INFO

# -- Monitoring Worker --
MONITORING_ENABLED=true
DEFAULT_CHECK_INTERVAL_SECONDS=60
DEFAULT_TIMEOUT_SECONDS=10
HEALTH_DISCOVERY_TIMEOUT_SECONDS=3

# -- Email (SMTP) --
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=monitor@company.internal
SMTP_TLS=true

# -- Telegram Bot --
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# -- Browser Push (VAPID) --
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=admin@company.internal

# -- Frontend --
NEXT_PUBLIC_API_URL=https://monitoring-system-api.ccrolabs.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
